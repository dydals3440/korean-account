{
  "name": "korean-account",
  "version": "0.1.3",
  "description": "Korean bank account detector · 한국 계좌번호 식별·과목 추출 — KFTC CMS PDF 충실, TypeScript.",
  "keywords": [
    "korean",
    "account",
    "bank",
    "validation",
    "detection",
    "fintech",
    "kftc",
    "한국",
    "계좌",
    "계좌번호",
    "은행",
    "금융결제원",
    "cms"
  ],
  "homepage": "https://github.com/dydals3440/korean-account#readme",
  "bugs": {
    "url": "https://github.com/dydals3440/korean-account/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dydals3440/korean-account.git"
  },
  "license": "MIT",
  "author": {
    "name": "Matthew Kim",
    "email": "dydals3440@gmail.com"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": {
        "import": "./dist/schema.d.ts",
        "require": "./dist/schema.d.cts"
      },
      "import": "./dist/schema.js",
      "require": "./dist/schema.cjs",
      "default": "./dist/schema.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "schema": [
        "./dist/schema.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "DOCS.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:bench": "vitest bench --run",
    "publint": "publint",
    "check:dist": "pnpm size && pnpm check:runtime",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "prepublishOnly": "pnpm build && pnpm check:dist",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "size": "size-limit",
    "check:runtime": "node scripts/check-runtime.mjs"
  },
  "peerDependencies": {
    "zod": "^3.23.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.5",
    "@biomejs/biome": "^2.5.4",
    "@changesets/cli": "^2.27.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "publint": "^0.3.0",
    "size-limit": "^12.1.0",
    "tsdown": "^0.22.8",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "zod": "^3.23.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  }
}
